{
	"name": "@revotale/react-hooks",
	"version": "0.3.1",
	"description": "Small React hooks with a stable, typed API.",
	"license": "MIT",
	"author": "RevoTale",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RevoTale/react-hooks.git"
	},
	"homepage": "https://github.com/RevoTale/react-hooks#readme",
	"bugs": {
		"url": "https://github.com/RevoTale/react-hooks/issues"
	},
	"keywords": [
		"react",
		"react-hooks",
		"typescript"
	],
	"type": "module",
	"packageManager": "bun@1.3.13",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run clean && bun run build:types && bun run build:esm && bun run build:cjs",
		"build:cjs": "bun build src/index.ts --outfile dist/index.cjs --target browser --format cjs --external=react",
		"build:esm": "bun build src/index.ts --outfile dist/index.js --target browser --format esm --external=react",
		"build:types": "tsc --emitDeclarationOnly",
		"clean": "rm -rf dist",
		"fix": "biome check --write .",
		"lint": "biome check .",
		"prepack": "bun run build",
		"prepublishOnly": "bun run validate && bun run test && bun run build",
		"test": "bun test --preload ./test/setup.ts",
		"typecheck": "tsc --noEmit",
		"validate": "bun run lint && bun run typecheck"
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/jsdom": "^28.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"jsdom": "^29.1.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"typescript": "^6.0.0"
	}
}
